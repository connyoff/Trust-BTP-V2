{
  "name": "Dapp surepay",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"        
      },
      "extensions": [
        "juanblanco.solidity",
        "dbaeumer.vscode-eslint",
        "dsznajder.es7-react-js-snippets",
	      "anthropic.claude-code"
      ]
    }
  },
  "workspaceFolder": "/workspaces/surepay",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/surepay,type=bind",  
  // "postCreateCommand": "npm install"
  "postCreateCommand": "curl -fsSL https://claude.ai/install.sh | bash",
  "postStartCommand": "rm -rf cache artifacts .hardhat"
}
